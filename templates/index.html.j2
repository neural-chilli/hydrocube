<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HydroCube — {{ cube_name }}</title>

  <link id="theme-css"    rel="stylesheet" href="/assets/bootswatch/flatly.min.css">
  <link id="psp-theme-css" rel="stylesheet" href="/assets/perspective/css/pro.css">
  <link rel="stylesheet"                    href="/assets/perspective/css/icons.css">
  <link rel="stylesheet"                    href="/assets/codemirror/codemirror.min.css">

  <style>
    /* ── Layout ──────────────────────────────────────────────────────────── */
    html, body { height: 100%; margin: 0; overflow: hidden; }
    body { display: flex; flex-direction: column; }

    /* ── Navbar ──────────────────────────────────────────────────────────── */
    #top-nav {
      flex: 0 0 auto;
      height: 48px;
      background-color: #3d5a78 !important;
      border-bottom: 1px solid #2e4560;
      display: flex;
      align-items: center;
      padding: 0 10px;
      gap: 6px;
      z-index: 1030;
    }

    .nav-btn {
      color: rgba(255,255,255,.88);
      border: 1px solid rgba(255,255,255,.26);
      background: transparent;
      border-radius: 4px;
      padding: 3px 9px;
      font-size: .81rem;
      cursor: pointer;
      white-space: nowrap;
      line-height: 1.5;
      user-select: none;
    }
    .nav-btn:hover  { background: rgba(255,255,255,.13); }
    .nav-btn:active { background: rgba(255,255,255,.22); }
    .nav-btn:disabled { opacity: .45; cursor: default; }

    #top-nav .dropdown-toggle { display: flex; align-items: center; gap: 4px; }
    #top-nav .dropdown-menu   { color: var(--bs-body-color); }

    #nav-brand {
      color: rgba(255,255,255,.92);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: .01em;
      white-space: nowrap;
    }
    #nav-spacer { flex: 1 1 auto; }

    /* Divider between nav control groups */
    .nav-sep {
      width: 1px;
      height: 22px;
      background: rgba(255,255,255,.2);
      flex-shrink: 0;
    }

    /* Zoom label inside the +/- group */
    #zoom-label {
      color: rgba(255,255,255,.7);
      font-size: .76rem;
      min-width: 36px;
      text-align: center;
      user-select: none;
    }

    /* ── Perspective wrapper ────────────────────────────────────────────── */
    #perspective-wrapper {
      flex: 1 1 auto;
      position: relative;
      overflow: hidden;
      min-height: 0;
      /* Slightly muted background visible beneath Pro Light theme */
      background: #eef1f5;
    }
    [data-bs-theme="dark"] #perspective-wrapper { background: #1a1f2b; }

    /* Intermediate zoom host: the transform lives here, NOT on perspective-viewer.
       This ensures Perspective's own getBoundingClientRect() / offsetWidth calls
       always see the unscaled element dimensions, preventing column-width drift. */
    #psp-zoom-host {
      position: absolute;
      top: 0;
      left: 0;
      transform-origin: top left;
      overflow: hidden;   /* clip any internal overflow at this layer */
    }

    perspective-viewer {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Loading/error overlay */
    #psp-loading {
      position: absolute;
      inset: 0;
      z-index: 5;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      background: #eef1f5;
      color: #6c757d;
      font-style: italic;
      transition: opacity .3s;
    }
    [data-bs-theme="dark"] #psp-loading { background: #1a1f2b; color: #8d99ae; }
    #psp-loading.hidden { opacity: 0; pointer-events: none; }

    .psp-spinner {
      width: 34px; height: 34px;
      border: 3px solid rgba(61,90,120,.18);
      border-top-color: #3d5a78;
      border-radius: 50%;
      animation: hc-spin .85s linear infinite;
    }
    @keyframes hc-spin { to { transform: rotate(360deg); } }

    /* ── Status strip ───────────────────────────────────────────────────── */
    #status-strip {
      flex: 0 0 auto;
      height: 26px;
      background: #3d5a78;
      border-top: 1px solid #2e4560;
      color: rgba(255,255,255,.68);
      font-size: .76rem;
      padding: 0 16px;
      display: flex;
      align-items: center;
      gap: 20px;
      overflow: hidden;
    }
    #status-strip strong { color: rgba(255,255,255,.92); }

    .sse-dot {
      display: inline-block;
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #ff6b6b;
      vertical-align: middle;
      margin-right: 4px;
      animation: hc-pulse 1.8s ease-in-out infinite;
    }
    .sse-dot.connected { background: #51cf66; animation: none; }
    @keyframes hc-pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── Alerts panel ───────────────────────────────────────────────────── */
    #alerts-panel {
      position: fixed;
      top: 48px; right: 0;
      width: 360px;
      max-height: calc(100vh - 48px - 26px);
      overflow-y: auto;
      z-index: 1025;
      box-shadow: -4px 0 20px rgba(0,0,0,.18);
      display: none;
    }
    #alerts-panel.show { display: block; }

    /* ── CodeMirror ─────────────────────────────────────────────────────── */
    .CodeMirror {
      height: 140px;
      font-size: 13px;
      font-family: 'SFMono-Regular', Menlo, monospace;
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════ Navbar -->
<nav id="top-nav">

  <!-- Brand -->
  <img src="/assets/images/hydrocube-logo.webp" alt="" height="26"
       style="border-radius:5px;flex-shrink:0" onerror="this.style.display='none'">
  <span id="nav-brand">HydroCube</span>

  <!-- Cube selector -->
  <div class="dropdown ms-1">
    <button class="nav-btn dropdown-toggle" data-bs-toggle="dropdown">
      ⬡ {{ cube_name }}
    </button>
    <ul class="dropdown-menu shadow-sm">
      <li><a class="dropdown-item active" href="#">{{ cube_name }}</a></li>
      <li><hr class="dropdown-divider"></li>
      <li><a class="dropdown-item text-muted" href="#"><em>Connect to another cube…</em></a></li>
    </ul>
  </div>

  <!-- Saved views -->
  <div class="dropdown">
    <button class="nav-btn dropdown-toggle" id="views-toggle-btn" data-bs-toggle="dropdown">
      📋 <span id="current-view-label">Default View</span>
    </button>
    <ul class="dropdown-menu shadow-sm" id="views-menu">
      <li><a class="dropdown-item active" href="#" data-view="__default__">Default View</a></li>
      <li><hr class="dropdown-divider" id="views-divider"></li>
      <li><a class="dropdown-item" href="#" id="save-view-btn">
        <em>Save current view…</em>
      </a></li>
    </ul>
  </div>

  <div id="nav-spacer"></div>

  <!-- SQL -->
  <button class="nav-btn" data-bs-toggle="modal" data-bs-target="#sql-modal" title="Ad-hoc SQL">SQL</button>

  <div class="nav-sep"></div>

  <!-- Perspective zoom controls (scales the viewer content only) -->
  <button class="nav-btn" id="zoom-out-btn" title="Zoom out">−</button>
  <span id="zoom-label">100%</span>
  <button class="nav-btn" id="zoom-in-btn"  title="Zoom in">+</button>

  <div class="nav-sep"></div>

  <!-- Fullscreen -->
  <button class="nav-btn" id="fullscreen-btn" title="Fullscreen">⛶</button>

  <!-- Theme toggle -->
  <button class="nav-btn" id="theme-btn" title="Toggle light/dark">🌙</button>

  <!-- Alerts bell -->
  <div style="position:relative">
    <button class="nav-btn" id="alerts-toggle" title="Alerts">🔔</button>
    <span id="alert-badge" class="position-absolute badge rounded-pill bg-danger"
          style="top:-5px;right:-5px;font-size:.6rem;min-width:16px;display:none">0</span>
  </div>

</nav>


<!-- ═══════════════════════════════════════════════════ Perspective pane -->
<div id="perspective-wrapper">
  <div id="psp-loading">
    <div class="psp-spinner"></div>
    <div>Connecting to HydroCube…</div>
  </div>
  <!-- Transform applied to this host div, never directly to perspective-viewer,
       so Perspective's internal measurements always see unscaled dimensions. -->
  <div id="psp-zoom-host">
    <perspective-viewer id="perspective-viewer" theme="Pro Light"></perspective-viewer>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════ Status strip -->
<div id="status-strip">
  <span><span class="sse-dot" id="sse-dot"></span><span id="sse-label">Connecting…</span></span>
  <span>Window: <strong id="stat-window">—</strong></span>
  <span>Rate: <strong id="stat-rate">0 Δ/s</strong></span>
  <span>Compacted: <strong id="stat-cutoff">—</strong></span>
  <span class="ms-auto">Clients: <strong id="stat-clients">—</strong></span>
  <span>Uptime: <strong id="stat-uptime">—</strong></span>
</div>


<!-- ═══════════════════════════════════════════════════ Alerts panel -->
<div id="alerts-panel" class="card border-0 rounded-0">
  <div class="card-header d-flex justify-content-between align-items-center py-2">
    <span class="fw-semibold">🔔 Alerts</span>
    <button class="btn btn-sm btn-outline-secondary" id="alerts-close">✕</button>
  </div>
  <div id="alerts-active" class="card-body border-bottom py-2" style="display:none">
    <div class="fw-semibold small mb-2 text-danger">Active</div>
    <div id="alerts-active-list" class="d-flex flex-column gap-2"></div>
  </div>
  <div class="card-body py-3 text-center text-muted small fst-italic">No alerts.</div>
  <div class="card-footer py-1 small text-center">
    <a href="#" class="text-muted">Configure alert rules…</a>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════ SQL Modal -->
<div class="modal fade" id="sql-modal" tabindex="-1" aria-labelledby="sql-modal-label">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title fw-semibold" id="sql-modal-label">Ad-hoc SQL Query</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pb-2">
        <textarea id="sql-editor" class="form-control font-monospace" rows="5"
                  style="font-size:.84rem;resize:vertical">SELECT * FROM agg LIMIT 100</textarea>
        <div class="text-muted small mt-1">
          Tables: <code>agg</code> (aggregated view) · <code>slices</code> (raw window data)
        </div>
      </div>
      <div class="modal-footer py-2 d-flex justify-content-between align-items-center gap-2">
        <span id="sql-meta" class="small text-muted"></span>
        <div class="d-flex gap-2">
          <button class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-sm btn-primary" id="run-query-btn">▶ Run</button>
        </div>
      </div>
      <div id="sql-result" class="border-top font-monospace small px-3 py-2"
           style="display:none;max-height:280px;overflow-y:auto"></div>
    </div>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════ Scripts -->
<script src="/assets/bootstrap/bootstrap.bundle.min.js"></script>
<script src="/assets/codemirror/codemirror.min.js"></script>
<script src="/assets/codemirror/sql.min.js"></script>

<script type="module">
import perspective from '/assets/perspective/cdn/perspective.js';
import '/assets/perspective/cdn/perspective-viewer.js';
import '/assets/perspective/cdn/perspective-viewer-datagrid.js';
import '/assets/perspective/cdn/perspective-viewer-d3fc.js';

// ── Constants ─────────────────────────────────────────────────────────────────
const CUBE        = '{{ cube_name }}';
const VIEWS_KEY   = `hc_views_${CUBE}`;
const LAST_VIEW_KEY = `hc_last_view_${CUBE}`;
const ZOOM_KEY    = 'hc_zoom';
const ZOOM_STEPS  = [0.5, 0.67, 0.75, 0.8, 0.9, 1.0, 1.1, 1.25, 1.5, 1.75, 2.0];

// ── Theme ─────────────────────────────────────────────────────────────────────
const THEMES = {
  light: '/assets/bootswatch/flatly.min.css',
  dark:  '/assets/bootswatch/darkly.min.css',
};
const PSP_THEMES = {
  light: '/assets/perspective/css/pro.css',
  dark:  '/assets/perspective/css/pro-dark.css',
};
let currentTheme = localStorage.getItem('hc_theme') || 'light';

const viewerEl   = document.getElementById('perspective-viewer');
const pspLoading = document.getElementById('psp-loading');

function applyTheme(t) {
  document.getElementById('theme-css').href     = THEMES[t]     ?? THEMES.light;
  document.getElementById('psp-theme-css').href = PSP_THEMES[t] ?? PSP_THEMES.light;
  document.documentElement.setAttribute('data-bs-theme', t);
  document.getElementById('theme-btn').textContent = t === 'dark' ? '☀️' : '🌙';
  if (viewerEl) viewerEl.setAttribute('theme', t === 'dark' ? 'Pro Dark' : 'Pro Light');
  currentTheme = t;
  localStorage.setItem('hc_theme', t);
}

applyTheme(currentTheme);
document.getElementById('theme-btn').addEventListener('click', () =>
  applyTheme(currentTheme === 'dark' ? 'light' : 'dark'));


// ── Perspective zoom ──────────────────────────────────────────────────────────
// The transform is applied to #psp-zoom-host, NOT to perspective-viewer itself.
// This ensures Perspective's internal getBoundingClientRect() / offsetWidth calls
// always see the true unscaled element dimensions, preventing column-width drift
// that occurs when scale() is placed directly on the custom element.
let zoomIdx = ZOOM_STEPS.indexOf(
  parseFloat(localStorage.getItem(ZOOM_KEY) || '1')
);
if (zoomIdx < 0) zoomIdx = ZOOM_STEPS.indexOf(1.0);

const pspWrapper  = document.getElementById('perspective-wrapper');
const pspZoomHost = document.getElementById('psp-zoom-host');

function applyZoom() {
  const z = ZOOM_STEPS[zoomIdx];
  const w = pspWrapper.clientWidth;
  const h = pspWrapper.clientHeight;
  // Size the zoom host to unscaled dimensions; perspective-viewer fills it at 100%.
  pspZoomHost.style.width     = Math.round(w / z) + 'px';
  pspZoomHost.style.height    = Math.round(h / z) + 'px';
  pspZoomHost.style.transform = `scale(${z})`;
  document.getElementById('zoom-label').textContent = Math.round(z * 100) + '%';
  document.getElementById('zoom-out-btn').disabled = (zoomIdx === 0);
  document.getElementById('zoom-in-btn').disabled  = (zoomIdx === ZOOM_STEPS.length - 1);
  localStorage.setItem(ZOOM_KEY, z);
}

// Re-apply on window resize. Debounce to prevent ResizeObserver feedback loops.
let _zoomResizeTimer;
new ResizeObserver(() => {
  clearTimeout(_zoomResizeTimer);
  _zoomResizeTimer = setTimeout(applyZoom, 80);
}).observe(pspWrapper);

document.getElementById('zoom-out-btn').addEventListener('click', () => {
  if (zoomIdx > 0) { zoomIdx--; applyZoom(); }
});
document.getElementById('zoom-in-btn').addEventListener('click', () => {
  if (zoomIdx < ZOOM_STEPS.length - 1) { zoomIdx++; applyZoom(); }
});

applyZoom();


// ── Fullscreen ────────────────────────────────────────────────────────────────
const wrapper      = document.getElementById('perspective-wrapper');
const fullscreenBtn = document.getElementById('fullscreen-btn');

fullscreenBtn.addEventListener('click', () => {
  if (!document.fullscreenElement) {
    wrapper.requestFullscreen().catch(() => {});
  } else {
    document.exitFullscreen();
  }
});

document.addEventListener('fullscreenchange', () => {
  fullscreenBtn.textContent = document.fullscreenElement ? '✕' : '⛶';
  fullscreenBtn.title       = document.fullscreenElement ? 'Exit fullscreen' : 'Fullscreen';
});


// ── Perspective table ─────────────────────────────────────────────────────────
let worker = null;
let table  = null;

function b64ToBuffer(b64) {
  const raw = atob(b64);
  const buf = new Uint8Array(raw.length);
  for (let i = 0; i < raw.length; i++) buf[i] = raw.charCodeAt(i);
  return buf.buffer;
}

// First load: fetch full snapshot, create indexed table, attach to viewer.
async function loadSnapshot() {
  try {
    const resp = await fetch('/api/snapshot');
    if (!resp.ok) return false;
    const data = await resp.json();
    if (!data.arrow_ipc_b64 || data.row_count === 0) return false;

    const buf = b64ToBuffer(data.arrow_ipc_b64);

    if (!table) {
      worker = await perspective.worker();
      // _key is auto-injected by the engine as CONCAT_WS('|', ...dimensions)
      // Using it as the Perspective index enables true row-level upserts.
      table = await worker.table(buf, { index: '_key' });
      await viewerEl.load(table);
      pspLoading.classList.add('hidden');
      await restoreLastView();
    } else {
      // Periodic full resync (handles deletions / any drift from delta path).
      await table.replace(buf);
    }
    return true;
  } catch (err) {
    console.warn('[HydroCube] snapshot error:', err);
    if (!table) {
      pspLoading.innerHTML =
        `<div class="text-danger small px-4 text-center">
           Failed to load Perspective: ${err.message}<br>
           <span class="text-muted">Check the browser console for details.</span>
         </div>`;
    }
    return false;
  }
}

loadSnapshot();

// Full resync every 60 s to handle any row deletions / compaction drift.
setInterval(() => { if (table) loadSnapshot(); }, 60_000);


// ── Delta rate ────────────────────────────────────────────────────────────────
let deltaTs = [];
function recordDelta() { deltaTs.push(Date.now()); }

setInterval(() => {
  const now = Date.now();
  deltaTs = deltaTs.filter(t => now - t < 1000);
  document.getElementById('stat-rate').textContent = deltaTs.length + ' Δ/s';
}, 500);


// ── SSE — true upserts via table.update() ─────────────────────────────────────
const sseDot   = document.getElementById('sse-dot');
const sseLabel = document.getElementById('sse-label');

function connectSSE() {
  const es = new EventSource('/api/stream');

  es.addEventListener('delta', async (event) => {
    recordDelta();
    if (table && event.data) {
      try {
        // Use the delta Arrow IPC directly — no snapshot round-trip needed.
        // _key index lets Perspective upsert only the changed rows.
        await table.update(b64ToBuffer(event.data));
      } catch (err) {
        console.warn('[HydroCube] delta update failed, resyncing:', err);
        await loadSnapshot();
      }
    } else {
      await loadSnapshot();
    }
  });

  es.onopen = () => {
    sseDot.classList.add('connected');
    sseLabel.textContent = 'Connected';
  };

  es.onerror = () => {
    sseDot.classList.remove('connected');
    sseLabel.textContent = 'Reconnecting…';
    es.close();
    setTimeout(connectSSE, 3000);
  };
}

connectSSE();


// ── Status polling ────────────────────────────────────────────────────────────
function fmtUptime(s) {
  if (s >= 3600) return `${Math.floor(s/3600)}h ${Math.floor((s%3600)/60)}m`;
  return `${Math.floor(s/60)}m ${s%60}s`;
}

function pollStatus() {
  fetch('/api/status').then(r => r.json()).then(s => {
    document.getElementById('stat-window').textContent  = s.window_id ?? '—';
    document.getElementById('stat-cutoff').textContent  =
      s.compaction_cutoff > 0 ? `W#${s.compaction_cutoff}` : 'none';
    document.getElementById('stat-clients').textContent = s.sse_client_count ?? '—';
    document.getElementById('stat-uptime').textContent  = fmtUptime(s.uptime_secs ?? 0);
  }).catch(() => {});
}

pollStatus();
setInterval(pollStatus, 5000);


// ── Alerts panel ──────────────────────────────────────────────────────────────
const alertsPanel = document.getElementById('alerts-panel');

document.getElementById('alerts-toggle').addEventListener('click', () => {
  alertsPanel.classList.toggle('show');
  if (alertsPanel.classList.contains('show'))
    document.getElementById('alert-badge').style.display = 'none';
});
document.getElementById('alerts-close').addEventListener('click', () =>
  alertsPanel.classList.remove('show'));


// ── Views — save / restore per cube ──────────────────────────────────────────
function loadViews() {
  try { return JSON.parse(localStorage.getItem(VIEWS_KEY) || '{}'); } catch { return {}; }
}
function saveViews(v) { localStorage.setItem(VIEWS_KEY, JSON.stringify(v)); }

function setActiveViewLabel(name) {
  document.getElementById('current-view-label').textContent = name;
  document.querySelectorAll('#views-menu [data-view]').forEach(el =>
    el.classList.toggle('active', el.dataset.view === name));
  localStorage.setItem(LAST_VIEW_KEY, name);
}

async function applyView(name) {
  if (name === '__default__') {
    await viewerEl.reset();
    setActiveViewLabel('Default View');
    return;
  }
  const views = loadViews();
  if (!views[name]) return;
  try {
    await viewerEl.restore(views[name]);
    setActiveViewLabel(name);
  } catch (e) {
    console.warn('[HydroCube] restore view failed:', e);
  }
}

// Restore the last-used view after first data load.
async function restoreLastView() {
  // Rebuild dropdown from stored views
  const views = loadViews();
  const menu  = document.getElementById('views-menu');
  const divider = document.getElementById('views-divider');
  for (const name of Object.keys(views)) {
    if (!menu.querySelector(`[data-view="${CSS.escape(name)}"]`)) {
      const li = document.createElement('li');
      li.innerHTML = `<a class="dropdown-item" href="#" data-view="${name}">${name}</a>`;
      menu.insertBefore(li, divider);
    }
  }
  const last = localStorage.getItem(LAST_VIEW_KEY);
  if (last && last !== '__default__' && views[last]) {
    await applyView(last);
  }
}

document.getElementById('views-menu').addEventListener('click', async (e) => {
  const item = e.target.closest('[data-view]');
  if (!item) return;
  e.preventDefault();
  await applyView(item.dataset.view);
});

document.getElementById('save-view-btn').addEventListener('click', async (e) => {
  e.preventDefault();
  if (!viewerEl) return;
  const name = prompt('Save view as:', 'My View');
  if (!name?.trim()) return;
  const cfg   = await viewerEl.save();
  const views = loadViews();
  views[name] = cfg;
  saveViews(views);
  const menu = document.getElementById('views-menu');
  const divider = document.getElementById('views-divider');
  if (!menu.querySelector(`[data-view="${CSS.escape(name)}"]`)) {
    const li = document.createElement('li');
    li.innerHTML = `<a class="dropdown-item" href="#" data-view="${name}">${name}</a>`;
    menu.insertBefore(li, divider);
  }
  setActiveViewLabel(name);
});


// ── SQL ───────────────────────────────────────────────────────────────────────
let sqlEditor;
if (typeof CodeMirror !== 'undefined') {
  sqlEditor = CodeMirror.fromTextArea(document.getElementById('sql-editor'), {
    mode: 'text/x-sql', lineNumbers: true, tabSize: 2, indentWithTabs: false,
  });
}

document.getElementById('run-query-btn').addEventListener('click', async function () {
  const sql = (sqlEditor ? sqlEditor.getValue() : document.getElementById('sql-editor').value).trim();
  if (!sql) return;
  const btn = this;
  const meta = document.getElementById('sql-meta');
  const result = document.getElementById('sql-result');
  btn.disabled = true; btn.textContent = '⏳';
  meta.textContent = ''; meta.style.color = '';
  result.style.display = 'none';
  try {
    const resp = await fetch('/api/query', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sql }),
    });
    const data = await resp.json();
    if (!resp.ok) throw new Error(data.error ?? resp.statusText);
    meta.textContent = `${data.row_count} row${data.row_count === 1 ? '' : 's'} returned`;
    result.style.display = '';
    result.innerHTML = `<span class="text-muted">Arrow IPC — ${data.row_count} rows returned.</span>`;
  } catch (err) {
    meta.textContent = 'Error: ' + err.message;
    meta.style.color = 'var(--bs-danger)';
  } finally {
    btn.disabled = false; btn.textContent = '▶ Run';
  }
});

</script>
</body>
</html>
